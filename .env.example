# Anthropic
ANTHROPIC_API_KEY=

# Confluence
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# Confluence — optional
CONFLUENCE_GOLD_STANDARD_PAGE_ID=   # Page ID of your best spec, used as a formatting template
CONFLUENCE_LOG_PAGE_ID=             # Pin the Spec Activity Log page ID to prevent duplicates on restart
CONFLUENCE_WEBHOOK_SECRET=           # Shared secret set when creating the Confluence webhook

# Recall.ai
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_WEBHOOK_URL=https://YOUR_DOMAIN/recall/webhook

# Recall.ai — optional
RECALL_WEBHOOK_SECRET=               # Shared secret for Recall webhook signature verification
